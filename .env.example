# =============================================================
# Quant-Alpha Environment Variables — TEMPLATE (값 없음)
# 실제 값은 .env 파일에 기입. 이 파일은 git에 커밋됩니다.
# =============================================================

# PostgreSQL / TimescaleDB
POSTGRES_USER=quant
POSTGRES_PASSWORD=
POSTGRES_DB=quant_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=
GRAFANA_PORT=3000

# Prefect
PREFECT_API_URL=http://localhost:4200/api

# Uptime Kuma
UPTIME_KUMA_PORT=3001

# Trading Mode (paper | live) — live면 실주문 가능, 기본값은 반드시 paper
TRADING_MODE=paper

# Broker API Keys
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=

# Anthropic Claude API
ANTHROPIC_API_KEY=

# Slack (알림용)
SLACK_WEBHOOK_URL=
SLACK_BOT_TOKEN=

# Sentry (에러 추적)
SENTRY_DSN=
